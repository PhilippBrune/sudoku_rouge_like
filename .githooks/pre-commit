#!/usr/bin/env bash
set -euo pipefail

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "tools/check-script-tree-drift.ps1" -ExpectNestedRoot
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "tools/check-script-tree-drift.ps1" -ExpectNestedRoot
else
  echo "Error: neither pwsh nor powershell is available for script-tree check." >&2
  exit 1
fi

blocked_retired_cs="$(git diff --cached --name-only --diff-filter=ACMR | grep -Ei '^retired/.*\.cs$' || true)"
if [ -n "$blocked_retired_cs" ]; then
  echo "Error: staged C# files under retired/ are not allowed:" >&2
  echo "$blocked_retired_cs" >&2
  exit 1
fi
